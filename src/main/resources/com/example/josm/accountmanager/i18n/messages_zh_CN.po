msgid "The server rejected these credentials (HTTP {0})."
msgstr "服务器拒绝了这些凭据（HTTP {0}）。"

msgctxt "account_manager"
msgid "The API URL is not an OSM-compatible API endpoint (HTTP 404)."
msgstr "该 API 地址不是兼容 OSM 的 API 端点（HTTP 404）。"

#, java-format
msgctxt "account_manager"
msgid "The account validation request failed (HTTP {0}: {1})."
msgstr "账户验证请求失败（HTTP {0}：{1}）。"

