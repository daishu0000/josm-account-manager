msgid "Credentials are stored in the current JOSM credential manager."
msgstr "凭据已保存在当前 JOSM 凭据管理器中。"

msgctxt "account_manager"
msgid "No credentials are stored. Edit this profile before activating it."
msgstr "尚未保存凭据。请先编辑此配置，再将其激活。"

