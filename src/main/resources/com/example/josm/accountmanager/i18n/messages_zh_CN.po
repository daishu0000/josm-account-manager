msgstr "此服务器没有为 JOSM 注册 OAuth 应用，请手动输入令牌。"

msgctxt "account_manager"
msgid "Authorization succeeded. The token was obtained automatically."
msgstr "授权成功，已自动获取令牌。"

msgctxt "account_manager"
msgid "Authorization failed or was canceled."
msgstr "授权失败或已取消。"

